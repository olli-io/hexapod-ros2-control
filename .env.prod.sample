# Sample env file for `hexa --prod` on the robot.
# Copy to .env on the Pi (~/hexa-prod/.env) and edit as needed.

# Host GID of the `input` group on the Pi. `getent group input | cut -d: -f3`
# on Ubuntu Server 24.04 typically prints 994. Override here if it differs.
INPUT_GID=994

# DDS domain. Anything sharing this ID on the local network sees each other's
# topics; pick a value that doesn't collide with other robots.
ROS_DOMAIN_ID=42

# Path to the Servo 2040 inside /dev on the Pi. /dev/ttyACM0 works for a
# single-board setup; switch to /dev/serial/by-id/usb-Pimoroni_Servo_2040-...
# once you know the stable string, so a re-enumerated bus number can't
# silently swap devices.
SERVO_DEVICE=/dev/ttyACM0
