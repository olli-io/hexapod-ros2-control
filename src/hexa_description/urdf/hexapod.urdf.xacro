<?xml version="1.0"?>
<!--
  Hexapod robot description (xacro).

  Coordinates follow REP-103 (the ROS standard for axes & units):
  looking down from above,
    +x = forward (nose of the robot)
    +y = left
    +z = up

  Each leg has 3 joints, named like the bug anatomy they imitate:
    coxa  — hip joint, rotates the whole leg left/right (around +z, "yaw")
    femur — shoulder joint, lifts the leg up/down (around +y, "pitch")
    tibia — knee joint, bends the lower leg up/down (around +y, "pitch")

  Each leg has its own (x, y) mount point on the body and its own
  "mount yaw" — the angle the leg points outward, measured
  counter-clockwise from forward (+x), looking down from above.
-->
<robot name="hexapod" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- =====================================================================
       Args.
       use_sim — when "true", pull in hexapod.gazebo.xacro (sim-only tags:
                 materials, friction, etc.). The real-robot bringup must
                 leave this false. See CLAUDE.md.
       ===================================================================== -->
  <xacro:arg name="use_sim" default="false"/>

  <!-- =====================================================================
       Config. Geometry (body/leg/foot dimensions, masses, per-leg mounts)
       and per-joint-type servo limits live together in geometry.yaml so
       they can be tuned without editing the URDF.
       ===================================================================== -->
  <xacro:property name="geom"
                  value="${xacro.load_yaml('$(find hexa_description)/config/geometry.yaml')}"/>

  <!-- Shortcuts for the values used repeatedly inside the leg macro.
       Sourced from geom so the YAML stays the single source of truth. -->
  <xacro:property name="coxa_length"  value="${geom['leg']['coxa_length']}"/>
  <xacro:property name="femur_length" value="${geom['leg']['femur_length']}"/>
  <xacro:property name="tibia_length" value="${geom['leg']['tibia_length']}"/>
  <xacro:property name="coxa_radius"  value="${geom['leg']['coxa_radius']}"/>
  <xacro:property name="femur_radius" value="${geom['leg']['femur_radius']}"/>
  <xacro:property name="tibia_radius" value="${geom['leg']['tibia_radius']}"/>
  <xacro:property name="coxa_mass"    value="${geom['leg']['coxa_mass']}"/>
  <xacro:property name="femur_mass"   value="${geom['leg']['femur_mass']}"/>
  <xacro:property name="tibia_mass"   value="${geom['leg']['tibia_mass']}"/>
  <xacro:property name="foot_radius"  value="${geom['foot']['radius']}"/>
  <xacro:property name="foot_mass"    value="${geom['foot']['mass']}"/>

  <!-- Per-joint <limit> windows, in URDF-convention radians. The YAML
       carries intuitive per-joint degrees (coxa.deg,
       femur.above_horizontal_deg, tibia.interior_deg with absolute
       lower_limit_deg / upper_limit_deg); the conversions here match
       hexa_kinematics/hexa_kinematics/joint_config.py exactly. The URDF
       itself stays a pure mathematical presentation of the hexapod —
       joint zero remains "legs splayed horizontally"; only the <limit>
       window is shifted to express the servo's reachable range.

       Sign-aware swap: femur uses -radians(deg) and tibia uses
       pi - radians(deg), both monotonically decreasing — so intuitive
       upper_limit_deg maps to URDF lower_rad and vice versa. -->
  <xacro:property name="coxa_lower_rad"
                  value="${geom['joints']['coxa']['lower_limit_deg'] * pi / 180}"/>
  <xacro:property name="coxa_upper_rad"
                  value="${geom['joints']['coxa']['upper_limit_deg'] * pi / 180}"/>
  <xacro:property name="femur_lower_rad"
                  value="${-geom['joints']['femur']['upper_limit_deg'] * pi / 180}"/>
  <xacro:property name="femur_upper_rad"
                  value="${-geom['joints']['femur']['lower_limit_deg'] * pi / 180}"/>
  <xacro:property name="tibia_lower_rad"
                  value="${pi - geom['joints']['tibia']['upper_limit_deg'] * pi / 180}"/>
  <xacro:property name="tibia_upper_rad"
                  value="${pi - geom['joints']['tibia']['lower_limit_deg'] * pi / 180}"/>

  <!-- Body length and width are derived from the front and middle mounts
       so the chassis always extends just past the hips: 10% margin per side. -->
  <xacro:property name="body_length" value="${2 * geom['mounts']['l_front']['x']  * 1.1}"/>
  <xacro:property name="body_width"  value="${2 * geom['mounts']['l_middle']['y'] * 1.1}"/>
  <xacro:property name="body_height" value="${geom['body']['height']}"/>
  <xacro:property name="body_mass"   value="${geom['body']['mass']}"/>

  <!-- =====================================================================
       Materials (just for colour in RViz / Gazebo).
       ===================================================================== -->
  <material name="body_grey"><color rgba="0.3 0.3 0.3 1.0"/></material>
  <material name="leg_blue"> <color rgba="0.2 0.4 0.8 1.0"/></material>

  <!-- =====================================================================
       Inertial macros. Both compute the tensor from mass + dimensions so
       the YAML stays the only place a number is typed. Declared before
       any link uses them: xacro requires macro definitions to precede
       their first use.
       ===================================================================== -->

  <!-- Solid cylinder of length L along the link's local +x:
         ixx = (1/2) m r^2          (about the long axis)
         iyy = izz = (1/12) m (3r^2 + L^2)
       COM at the segment midpoint. -->
  <xacro:macro name="cylinder_inertial" params="mass length radius">
    <inertial>
      <origin xyz="${length/2} 0 0" rpy="0 0 0"/>
      <mass value="${mass}"/>
      <inertia ixx="${0.5 * mass * radius * radius}"
               iyy="${mass * (3*radius*radius + length*length) / 12.0}"
               izz="${mass * (3*radius*radius + length*length) / 12.0}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- Solid box of side lengths (x, y, z):
         ixx = (1/12) m (y^2 + z^2)
         iyy = (1/12) m (x^2 + z^2)
         izz = (1/12) m (x^2 + y^2)
       COM at link origin (the body box is centred on base_link). -->
  <xacro:macro name="box_inertial" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <inertia ixx="${mass * (y*y + z*z) / 12.0}"
               iyy="${mass * (x*x + z*z) / 12.0}"
               izz="${mass * (x*x + y*y) / 12.0}"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- =====================================================================
       Body link — the central chassis everything else hangs off of.
       ===================================================================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
      <material name="body_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="${body_length} ${body_width} ${body_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertial mass="${body_mass}"
                        x="${body_length}"
                        y="${body_width}"
                        z="${body_height}"/>
  </link>

  <!-- =====================================================================
       Leg macro.

       Parameters:
         side       — "l" (left) or "r" (right), used only for naming.
         name       — leg identifier, e.g. "front", "middle", "rear".
         mount_x,
         mount_y    — hip position on the body (metres from centre).
         mount_yaw  — direction the leg points outward (radians),
                      measured counter-clockwise from +x (forward).
                      A leg "pointing straight left" has mount_yaw = +pi/2.
       ===================================================================== -->
  <xacro:macro name="leg" params="side name mount_x mount_y mount_yaw">

    <!-- Coxa: short horizontal segment attached to the body. -->
    <joint name="${side}_${name}_coxa_joint" type="revolute">
      <parent link="base_link"/>
      <child  link="${side}_${name}_coxa"/>
      <!-- Mount point on the body, rotated so the leg "points outward". -->
      <origin xyz="${mount_x} ${mount_y} 0" rpy="0 0 ${mount_yaw}"/>
      <!-- Rotates around +z = swings the leg forward/backward. -->
      <axis xyz="0 0 1"/>
      <limit lower="${coxa_lower_rad}"
             upper="${coxa_upper_rad}"
             effort="${geom['joints']['coxa']['effort']}"
             velocity="${geom['joints']['coxa']['velocity']}"/>
    </joint>

    <link name="${side}_${name}_coxa">
      <visual>
        <!-- Cylinder lies along the leg's local +x (outward from body). -->
        <origin xyz="${coxa_length/2} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="${coxa_radius}" length="${coxa_length}"/>
        </geometry>
        <material name="leg_blue"/>
      </visual>
      <!-- Joint caps: visual-only spheres at each end of the segment. -->
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="${coxa_radius}"/></geometry>
        <material name="leg_blue"/>
      </visual>
      <visual>
        <origin xyz="${coxa_length} 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="${coxa_radius}"/></geometry>
        <material name="leg_blue"/>
      </visual>
      <collision>
        <origin xyz="${coxa_length/2} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="${coxa_radius}" length="${coxa_length}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertial mass="${coxa_mass}"
                               length="${coxa_length}"
                               radius="${coxa_radius}"/>
    </link>

    <!-- Femur: upper leg, lifts the knee up/down. -->
    <joint name="${side}_${name}_femur_joint" type="revolute">
      <parent link="${side}_${name}_coxa"/>
      <child  link="${side}_${name}_femur"/>
      <!-- Attached at the far end of the coxa. -->
      <origin xyz="${coxa_length} 0 0" rpy="0 0 0"/>
      <!-- Rotates around the leg's local +y = lifts/lowers the femur. -->
      <axis xyz="0 1 0"/>
      <limit lower="${femur_lower_rad}"
             upper="${femur_upper_rad}"
             effort="${geom['joints']['femur']['effort']}"
             velocity="${geom['joints']['femur']['velocity']}"/>
    </joint>

    <link name="${side}_${name}_femur">
      <visual>
        <origin xyz="${femur_length/2} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="${femur_radius}" length="${femur_length}"/>
        </geometry>
        <material name="leg_blue"/>
      </visual>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="${femur_radius}"/></geometry>
        <material name="leg_blue"/>
      </visual>
      <visual>
        <origin xyz="${femur_length} 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="${femur_radius}"/></geometry>
        <material name="leg_blue"/>
      </visual>
      <collision>
        <origin xyz="${femur_length/2} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="${femur_radius}" length="${femur_length}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertial mass="${femur_mass}"
                               length="${femur_length}"
                               radius="${femur_radius}"/>
    </link>

    <!-- Tibia: lower leg, bends at the knee down to the foot. -->
    <joint name="${side}_${name}_tibia_joint" type="revolute">
      <parent link="${side}_${name}_femur"/>
      <child  link="${side}_${name}_tibia"/>
      <origin xyz="${femur_length} 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="${tibia_lower_rad}"
             upper="${tibia_upper_rad}"
             effort="${geom['joints']['tibia']['effort']}"
             velocity="${geom['joints']['tibia']['velocity']}"/>
    </joint>

    <link name="${side}_${name}_tibia">
      <visual>
        <origin xyz="${tibia_length/2} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="${tibia_radius}" length="${tibia_length}"/>
        </geometry>
        <material name="leg_blue"/>
      </visual>
      <!-- Proximal joint cap only; distal end is covered by the foot sphere. -->
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="${tibia_radius}"/></geometry>
        <material name="leg_blue"/>
      </visual>
      <collision>
        <origin xyz="${tibia_length/2} 0 0" rpy="0 ${pi/2} 0"/>
        <geometry>
          <cylinder radius="${tibia_radius}" length="${tibia_length}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertial mass="${tibia_mass}"
                               length="${tibia_length}"
                               radius="${tibia_radius}"/>
    </link>

    <!-- Foot: a small sphere at the tip of the tibia.
         Used as the IK target and as the ground-contact body in sim.
         The foot link origin sits at the bottom of the sphere along the
         tibia's +x axis, so the IK target coincides with the ground
         contact point under the assumption that the tibia is vertical
         at touchdown. The sphere geometry is therefore shifted back by
         -foot_radius in the foot frame to keep its centre at the
         physical tibia tip. -->
    <joint name="${side}_${name}_foot_joint" type="fixed">
      <parent link="${side}_${name}_tibia"/>
      <child  link="${side}_${name}_foot"/>
      <origin xyz="${tibia_length + foot_radius} 0 0" rpy="0 0 0"/>
    </joint>
    <link name="${side}_${name}_foot">
      <visual>
        <origin xyz="${-foot_radius} 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="${foot_radius}"/></geometry>
        <material name="leg_blue"/>
      </visual>
      <collision>
        <origin xyz="${-foot_radius} 0 0" rpy="0 0 0"/>
        <geometry><sphere radius="${foot_radius}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="${-foot_radius} 0 0" rpy="0 0 0"/>
        <mass value="${foot_mass}"/>
        <!-- Solid sphere: I = (2/5) m r^2, isotropic. -->
        <inertia ixx="${0.4 * foot_mass * foot_radius * foot_radius}"
                 iyy="${0.4 * foot_mass * foot_radius * foot_radius}"
                 izz="${0.4 * foot_mass * foot_radius * foot_radius}"
                 ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

  </xacro:macro>

  <!-- =====================================================================
       Instantiate the 6 legs. Only l_front and l_middle are defined in
       geometry.yaml; the other four legs derive by symmetry:
         - rear mirrors front about y-axis: x → -x, yaw → pi - yaw
         - right mirrors left  about x-axis: y → -y, yaw → -yaw
       Applying both gives r_rear from l_front, and so on.
       ===================================================================== -->
  <xacro:macro name="mount_leg" params="side name">
    <!-- Reference: middle legs use l_middle, front/rear use l_front. -->
    <xacro:property name="ref"
                    value="${geom['mounts']['l_middle' if name == 'middle' else 'l_front']}"/>
    <!-- Front/rear mirror (only affects rear): flips x, reflects yaw about pi/2. -->
    <xacro:property name="x_after_fr"   value="${-ref['x']   if name == 'rear' else ref['x']}"/>
    <xacro:property name="ref_yaw"      value="${ref['yaw_deg'] * pi / 180}"/>
    <xacro:property name="yaw_after_fr" value="${pi - ref_yaw if name == 'rear' else ref_yaw}"/>
    <!-- Left/right mirror (only affects right side): flips y, negates yaw. -->
    <xacro:property name="mx"  value="${x_after_fr}"/>
    <xacro:property name="my"  value="${-ref['y']     if side == 'r' else ref['y']}"/>
    <xacro:property name="myaw" value="${-yaw_after_fr if side == 'r' else yaw_after_fr}"/>
    <xacro:leg side="${side}" name="${name}"
               mount_x="${mx}" mount_y="${my}" mount_yaw="${myaw}"/>
  </xacro:macro>

  <xacro:mount_leg side="l" name="front"/>
  <xacro:mount_leg side="l" name="middle"/>
  <xacro:mount_leg side="l" name="rear"/>
  <xacro:mount_leg side="r" name="front"/>
  <xacro:mount_leg side="r" name="middle"/>
  <xacro:mount_leg side="r" name="rear"/>

  <!-- =====================================================================
       ros2_control hardware interface declarations.

       Lists every joint that ros2_control will command/observe. The
       <plugin> element swaps between the Gazebo and real-robot
       hardware_interface backends based on use_sim. The real-robot
       plugin lives in hexa_hardware (not yet implemented — the name
       here is the contract that package will fulfil).
       ===================================================================== -->
  <xacro:macro name="leg_joints_iface" params="side name">
    <joint name="${side}_${name}_coxa_joint">
      <command_interface name="position">
        <param name="min">${coxa_lower_rad}</param>
        <param name="max">${coxa_upper_rad}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="${side}_${name}_femur_joint">
      <command_interface name="position">
        <param name="min">${femur_lower_rad}</param>
        <param name="max">${femur_upper_rad}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="${side}_${name}_tibia_joint">
      <command_interface name="position">
        <param name="min">${tibia_lower_rad}</param>
        <param name="max">${tibia_upper_rad}</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </xacro:macro>

  <ros2_control name="HexaSystem" type="system">
    <hardware>
      <xacro:if value="$(arg use_sim)">
        <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      </xacro:if>
      <xacro:unless value="$(arg use_sim)">
        <plugin>hexa_hardware/HexaHardware</plugin>
      </xacro:unless>
    </hardware>
    <xacro:leg_joints_iface side="l" name="front"/>
    <xacro:leg_joints_iface side="l" name="middle"/>
    <xacro:leg_joints_iface side="l" name="rear"/>
    <xacro:leg_joints_iface side="r" name="front"/>
    <xacro:leg_joints_iface side="r" name="middle"/>
    <xacro:leg_joints_iface side="r" name="rear"/>
  </ros2_control>

  <!-- =====================================================================
       Gazebo overlay — included only in sim. Real-robot bringup leaves
       use_sim=false so none of these tags reach the robot_description topic.
       ===================================================================== -->
  <xacro:if value="$(arg use_sim)">
    <xacro:include filename="$(find hexa_description)/urdf/hexapod.gazebo.xacro"/>
  </xacro:if>

</robot>
