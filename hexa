#!/usr/bin/env bash
# Entry point for hexapod project commands (host side).
# Dispatches to per-process scripts under scripts/.
#   ./hexa --dev [args...]   -> drop into the ROS2 Jazzy dev container
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    cat <<EOF
Usage: ./hexa <command> [args...]

Commands:
  --dev [--clean] [--launch] [args...]
                              Drop into the ROS2 Jazzy dev container (forwards args to the container).
                              --clean tears down the existing container, rebuilds the image,
                              and runs 'pod build' before opening the shell.
                              --launch runs sim + teleop + webteleop in the shell (same as
                              --tmux pane 0, without the second pane).
  --tmux [--clean] [vert]     Open a tmux session with two panes sharing one dev container:
                              pane 0 runs sim + teleop + webteleop together, pane 1 is an idle 'hexa --dev' shell.
                              Default split is side-by-side; pass 'vert' to stack the panes.
                              --clean rebuilds the container first.
  --prod <subcommand> [args]  Cross-build + deploy + operate the production image on the robot.
                              Subcommands: build, deploy <host>, start, stop, restart, status,
                              logs [-f], shell, engage, disengage, teleop. Run with no
                              subcommand for the full list.
  kill                        Stop and remove the dev container.
  -h, --help                  Show this help message.
EOF
}

if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

cmd="$1"
shift

case "${cmd}" in
    --dev)
        clean=0
        launch=0
        dev_args=()
        for arg in "$@"; do
            case "${arg}" in
                --clean)  clean=1 ;;
                --launch) launch=1 ;;
                *)        dev_args+=("${arg}") ;;
            esac
        done
        if [[ ${clean} -eq 1 ]]; then
            "${REPO_ROOT}/scripts/kill.sh"
            "${REPO_ROOT}/scripts/dev.sh" pod build
        fi
        if [[ ${launch} -eq 1 ]]; then
            exec "${REPO_ROOT}/scripts/dev.sh" bash -c \
                "pod sim & echo 'waiting for sim (/clock)...'; until ros2 topic list 2>/dev/null | grep -q '^/clock\$'; do sleep 1; done; echo 'sim ready'; pod webteleop & pod teleop"
        fi
        exec "${REPO_ROOT}/scripts/dev.sh" "${dev_args[@]}"
        ;;
    --tmux)
        exec "${REPO_ROOT}/scripts/tmux.sh" "$@"
        ;;
    --prod)
        exec "${REPO_ROOT}/scripts/prod.sh" "$@"
        ;;
    kill)
        exec "${REPO_ROOT}/scripts/kill.sh" "$@"
        ;;
    -h|--help)
        usage
        ;;
    *)
        echo "Unknown command: ${cmd}" >&2
        usage
        exit 1
        ;;
esac
